# Copy this file to .env and fill in real values. Never commit .env.

PORT=4000

# MongoDB Atlas connection string (from Atlas > Connect > Drivers).
# Create a free M0 cluster, a database user, and allow access from
# 0.0.0.0/0 in Network Access (or Render's specific IPs) if you don't
# want to manage an IP allowlist.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/smart_travel?retryWrites=true&w=majority

# Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Brevo (formerly Sendinblue) > SMTP & API > API Keys
BREVO_API_KEY=your-brevo-api-key
# Must be a sender you've verified in Brevo (Senders, Domains & Dedicated IPs).
BREVO_SENDER_EMAIL=you@example.com
BREVO_SENDER_NAME=Smart Travel Companion
